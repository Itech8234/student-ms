<header class="sticky top-0 z-40 bg-white/90 backdrop-blur border-b border-slate-200">
  <nav class="mx-auto max-w-7xl px-4 h-16 flex items-center justify-between" aria-label="Primary">
    <a href="/" class="flex items-center gap-2 font-semibold text-slate-900">
      <svg class="w-7 h-7 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 14l9-5-9-5-9 5 9 5z" />
        <path d="M12 14l6.16-3.422a12.083 12.083 0 0 1 .665 6.479A11.952 11.952 0 0 0 12 20.055a11.952 11.952 0 0 0-6.824-2.998 12.078 12.078 0 0 1 .665-6.479L12 14z" />
      </svg>
      LearnHub
    </a>

    <form
      hx-get="/courses/grid"
      hx-trigger="input changed delay:300ms from:input, search"
      hx-target="#catalog-grid"
      hx-swap="innerHTML"
      hx-push-url="true"
      class="hidden md:flex flex-1 max-w-md mx-6"
      role="search">
      <label for="q" class="sr-only">Search courses</label>
      <div class="relative w-full">
        <input
          id="q" name="q" type="search" placeholder="Search courses…" autocomplete="off"
          class="w-full pl-10 pr-3 py-2 rounded-lg border border-slate-300 focus:border-brand-500 focus:ring-brand-500" />
        <svg class="absolute left-3 top-2.5 w-5 h-5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" />
        </svg>
      </div>
    </form>

    <div id="user-widget" hx-get="/auth/me" hx-trigger="load delay:0" hx-swap="innerHTML">
      <a href="/login" class="text-sm font-medium text-brand-600 hover:text-brand-700">Sign in</a>
    </div>
  </nav>
</header>
