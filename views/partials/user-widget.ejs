<% if (user) { %>
  <div class="flex items-center gap-3">
    <a href="/dashboard" class="text-sm font-medium hover:text-brand-600">Dashboard</a>
    <% if (user.role === "instructor") { %>
      <a href="/instructor" class="text-sm font-medium hover:text-brand-600">Instructor</a>
    <% } %>
    <img src="<%= user.profile.photoURL || `https://api.dicebear.com/7.x/initials/svg?seed=${user.profile.displayName}` %>"
         alt="" class="w-8 h-8 rounded-full bg-slate-200" />
    <button data-action="logout" class="text-sm text-slate-500 hover:text-rose-600">Logout</button>
  </div>
<% } else { %>
  <a href="/login" class="text-sm font-medium text-brand-600 hover:text-brand-700">Sign in</a>
<% } %>
