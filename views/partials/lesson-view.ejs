<% const l = lesson; %>
<article class="max-w-3xl mx-auto px-6 py-8">
  <header class="mb-6">
    <p class="text-xs font-medium text-brand-600 uppercase tracking-wide"><%= l.type %></p>
    <h1 class="mt-1 text-2xl md:text-3xl font-bold text-slate-900"><%= l.title %></h1>
  </header>

  <% if (l.type === "video") { %>
    <div class="aspect-video bg-black rounded-xl overflow-hidden shadow-lg">
      <video controls preload="metadata" class="w-full h-full"
             data-lesson-video
             data-lesson-id="<%= l.id %>"
             data-course-id="<%= courseId %>"
             data-module-id="<%= l.moduleId %>"
             <% if (l.videoUrl) { %>src="<%= l.videoUrl %>"<% } %>>
        Your browser does not support HTML5 video.
      </video>
    </div>

    <div id="progress-<%= l.id %>" class="mt-4 flex items-center gap-2 text-sm text-slate-500">
      <% if (completedSet.includes(l.id)) { %>
        <span class="flex items-center gap-2 text-emerald-700">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7 7a1 1 0 01-1.4 0l-3-3a1 1 0 011.4-1.4L9 11.6l6.3-6.3a1 1 0 011.4 0z" clip-rule="evenodd"/>
          </svg>
          Completed
        </span>
      <% } else { %>
        <button hx-post="/progress/complete"
                hx-vals='{"courseId":"<%= courseId %>","moduleId":"<%= l.moduleId %>","lessonId":"<%= l.id %>"}'
                hx-target="#progress-<%= l.id %>"
                hx-swap="outerHTML"
                class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 focus:ring-2 focus:ring-brand-500">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 10l4 4L15 6"/>
          </svg>
          Mark as complete
        </button>
      <% } %>
    </div>
  <% } %>

  <% if (l.type === "text") { %>
    <div class="prose prose-slate max-w-none bg-white rounded-xl shadow p-6">
      <%- l.content?.body || "<p>No content.</p>" %>
    </div>
    <div id="progress-<%= l.id %>" class="mt-6">
      <% if (completedSet.includes(l.id)) { %>
        <span class="text-emerald-700 font-medium">✓ You've read this lesson</span>
      <% } else { %>
        <button hx-post="/progress/complete"
                hx-vals='{"courseId":"<%= courseId %>","moduleId":"<%= l.moduleId %>","lessonId":"<%= l.id %>"}'
                hx-target="#progress-<%= l.id %>"
                hx-swap="outerHTML"
                class="px-4 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-700">
          Mark as read
        </button>
      <% } %>
    </div>
  <% } %>

  <% if (l.type === "quiz") { %>
    <form hx-post="/lessons/<%= courseId %>/<%= l.id %>/quiz"
          hx-target="#quiz-result" hx-swap="innerHTML"
          class="bg-white rounded-xl shadow p-6 space-y-5">
      <% (l.content?.quiz || []).forEach((q, qi) => { %>
        <fieldset>
          <legend class="font-medium text-slate-900 mb-2"><%= qi + 1 %>. <%= q.q %></legend>
          <div class="space-y-1.5">
            <% q.options.forEach((opt, oi) => { %>
              <label class="flex items-center gap-2 p-2 rounded hover:bg-slate-50 cursor-pointer">
                <input type="radio" name="q<%= qi %>" value="<%= oi %>" class="text-brand-600 focus:ring-brand-500" required />
                <span class="text-sm text-slate-700"><%= opt %></span>
              </label>
            <% }) %>
          </div>
        </fieldset>
      <% }) %>
      <button type="submit" class="px-4 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-700">Submit quiz</button>
      <div id="quiz-result" class="mt-3"></div>
    </form>
  <% } %>

  <nav class="mt-10 flex items-center justify-between border-t border-slate-200 pt-6" aria-label="Lesson navigation">
    <% if (typeof prevLesson !== "undefined" && prevLesson) { %>
      <a href="?lesson=<%= prevLesson.id %>"
         hx-get="/lessons/<%= courseId %>/<%= prevLesson.id %>"
         hx-target="#lesson-stage" hx-swap="innerHTML" hx-push-url="true"
         class="text-sm text-slate-600 hover:text-brand-600">← Previous</a>
    <% } else { %><span></span><% } %>

    <% if (typeof nextLesson !== "undefined" && nextLesson) { %>
      <a href="?lesson=<%= nextLesson.id %>"
         hx-get="/lessons/<%= courseId %>/<%= nextLesson.id %>"
         hx-target="#lesson-stage" hx-swap="innerHTML" hx-push-url="true"
         class="text-sm font-medium text-brand-600 hover:text-brand-700">Next: <%= nextLesson.title %> →</a>
    <% } else if (completedSet.includes(l.id)) { %>
      <span class="text-sm text-emerald-700">🎉 Course complete!</span>
    <% } %>
  </nav>
</article>
