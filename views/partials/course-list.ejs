<% if (!items.length) { %>
  <p class="p-8 text-center text-slate-500">No courses yet. Create your first one.</p>
<% } %>

<% items.forEach(c => { %>
  <article class="p-4 flex items-center gap-4 hover:bg-slate-50">
    <div class="w-16 h-16 rounded-md bg-slate-100 flex-shrink-0 overflow-hidden">
      <% if (c.thumbnail) { %><img src="<%= c.thumbnail %>" alt="" class="w-full h-full object-cover" /><% } %>
    </div>
    <div class="flex-1 min-w-0">
      <a href="/instructor/courses/<%= c.id %>/edit" class="font-medium text-slate-900 hover:text-brand-600"><%= c.title %></a>
      <p class="text-xs text-slate-500 mt-0.5">
        <span class="px-2 py-0.5 rounded-full text-xs <%= c.status === 'published' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
          <%= c.status %>
        </span>
        · <%= c.modulesCount %> modules · <%= c.lessonsCount %> lessons · <%= c.enrolledCount %> students
      </p>
    </div>
    <a href="/instructor/courses/<%= c.id %>/edit" class="text-sm text-brand-600 hover:text-brand-700">Edit →</a>
  </article>
<% }) %>
