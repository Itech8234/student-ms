<section class="mx-auto max-w-7xl px-4 py-10">
  <header class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900">Welcome back, <%= currentUser.profile.displayName.split(" ")[0] %> 👋</h1>
    <p class="mt-1 text-slate-600">Pick up where you left off.</p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 bg-white rounded-xl shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Continue learning</h2>
      <div id="my-enrollments"
           hx-get="/enrollments/mine" hx-trigger="load" hx-swap="innerHTML"
           class="space-y-3">
        <div class="htmx-indicator text-sm text-slate-500">Loading your courses…</div>
      </div>
    </div>

    <div class="bg-gradient-to-br from-brand-600 to-brand-700 text-white rounded-xl shadow p-6">
      <h2 class="text-lg font-semibold">Your stats</h2>
      <dl class="mt-4 space-y-3 text-sm">
        <div class="flex justify-between"><dt>Enrolled</dt><dd class="font-semibold" id="stat-enrolled">—</dd></div>
        <div class="flex justify-between"><dt>In progress</dt><dd class="font-semibold" id="stat-in-progress">—</dd></div>
        <div class="flex justify-between"><dt>Completed</dt><dd class="font-semibold" id="stat-completed">—</dd></div>
      </dl>
    </div>
  </div>
</section>
