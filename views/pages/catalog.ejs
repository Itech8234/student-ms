<section class="bg-gradient-to-b from-brand-50 to-transparent">
  <div class="mx-auto max-w-7xl px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold text-slate-900">Find your next course</h1>
    <p class="mt-2 text-slate-600 max-w-xl">Learn from expert instructors. Track your progress. Pick up where you left off.</p>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-8">
  <div class="grid grid-cols-1 lg:grid-cols-[16rem_1fr] gap-8">
    <aside aria-label="Filters" class="space-y-6">
      <div>
        <h2 class="text-sm font-semibold text-slate-900 mb-2">Category</h2>
        <ul class="space-y-1 text-sm">
          <% const cats = ["backend","frontend","design","data","mobile"]; %>
          <% cats.forEach(c => { %>
            <li>
              <button hx-get="/courses/grid?category=<%= c %>"
                      hx-target="#catalog-grid" hx-swap="innerHTML" hx-push-url="true"
                      class="w-full text-left px-2 py-1.5 rounded hover:bg-slate-100 focus:bg-slate-100">
                <%= c[0].toUpperCase() + c.slice(1) %>
              </button>
            </li>
          <% }) %>
        </ul>
      </div>
    </aside>

    <div id="catalog-grid"
         hx-get="/courses/grid" hx-trigger="load" hx-swap="innerHTML"
         class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
      <div class="htmx-indicator col-span-full text-center py-12 text-slate-500">Loading courses…</div>
    </div>
  </div>
</section>
