<section class="mx-auto max-w-4xl px-4 py-10">
  <h1 class="text-2xl font-bold mb-6">Create a new course</h1>

  <form id="course-form" hx-post="/instructor/courses" class="space-y-6">
    <div class="bg-white rounded-xl shadow p-6 space-y-4">
      <h2 class="font-semibold">Course details</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1" for="title">Title</label>
          <input id="title" name="title" required minlength="4" maxlength="120"
                 class="w-full rounded-lg border-slate-300 focus:border-brand-500 focus:ring-brand-500" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1" for="category">Category</label>
          <select id="category" name="category" required class="w-full rounded-lg border-slate-300">
            <option value="backend">Backend</option>
            <option value="frontend">Frontend</option>
            <option value="design">Design</option>
            <option value="data">Data</option>
            <option value="mobile">Mobile</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1" for="level">Level</label>
          <select id="level" name="level" required class="w-full rounded-lg border-slate-300">
            <option value="beginner">Beginner</option>
            <option value="intermediate">Intermediate</option>
            <option value="advanced">Advanced</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1" for="price">Price (USD)</label>
          <input id="price" name="price" type="number" min="0" step="1" value="0"
                 class="w-full rounded-lg border-slate-300" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" for="description">Description</label>
        <textarea id="description" name="description" rows="4" required minlength="20"
                  class="w-full rounded-lg border-slate-300"></textarea>
      </div>
    </div>

    <div class="flex justify-end gap-3">
      <a href="/instructor" class="px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50">Cancel</a>
      <button type="submit" class="px-5 py-2.5 rounded-lg bg-brand-600 text-white font-medium hover:bg-brand-700">
        Save & continue
      </button>
    </div>
  </form>
</section>
