<section class="mx-auto max-w-md px-4 py-24 text-center">
  <p class="text-6xl">⚠️</p>
  <h1 class="mt-4 text-2xl font-bold">Something went wrong</h1>
  <p class="mt-2 text-slate-600"><%= error.message %></p>
  <p class="mt-1 text-xs text-slate-400">Code: <%= error.code %></p>
  <a href="/" class="mt-6 inline-block px-4 py-2 bg-brand-600 text-white rounded-lg">Go home</a>
</section>
